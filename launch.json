{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Debug Next.js",
      "type": "node",
      "request": "launch",
      // Pekar på Next.js dev-kommandot direkt
      "program": "${workspaceFolder}/node_modules/next/dist/bin/next",
      "args": ["dev"],
      // Arbetar i din root-mapp (cvbrev)
      "cwd": "${workspaceFolder}",
      // Sätter Node i debug-läge
      "env": {
        "NODE_OPTIONS": "--inspect"
      },
      // Porten som Node Debug Protocol kör på
      "port": 9229,
      "skipFiles": [
        "<node_internals>/**"
      ]
    }
  ]
}
