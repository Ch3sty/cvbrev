          { "id": "c", "text": "40", "isCorrect": false },
          { "id": "d", "text": "45", "isCorrect": false }
        ],
        "correctAnswerId": "b",
        "explanation": "Deltidsanställda = totalt − heltid = 80 − 45 = 35 personer.",
