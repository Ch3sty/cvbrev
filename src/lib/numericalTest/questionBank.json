          { "id": "a", "text": "21 000 kr", "isCorrect": false },
          { "id": "b", "text": "25 200 kr", "isCorrect": true },
          { "id": "c", "text": "28 000 kr", "isCorrect": false },
          { "id": "d", "text": "33 600 kr", "isCorrect": false }
