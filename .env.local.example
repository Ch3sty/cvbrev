# SEO & Analytics Environment Variables

# Google Analytics 4
GA4_PROPERTY_ID=your_ga4_property_id
GA4_MEASUREMENT_ID=G-XXXXXXXXXX

# Google Search Console
SITE_URL=https://jobbcoach.ai
GOOGLE_SERVICE_ACCOUNT_KEY_FILE=path/to/service-account-key.json
# Alternativt som JSON string:
# GOOGLE_SERVICE_ACCOUNT_KEY={"type": "service_account", "project_id": "..."}

# Semrush API (för keyword research och competitor analysis)
SEMRUSH_API_KEY=your_semrush_api_key

# PageSpeed Insights API
PAGESPEED_API_KEY=your_pagespeed_api_key

# Core Web Vitals monitoring
WEB_VITALS_ENDPOINT=your_custom_endpoint_for_web_vitals

# Swedish specific settings
DEFAULT_COUNTRY=SE
DEFAULT_LANGUAGE=sv-SE
TIMEZONE=Europe/Stockholm

# Content tracking
ENABLE_USER_JOURNEY_TRACKING=true
ENABLE_SCROLL_TRACKING=true
ENABLE_CTA_TRACKING=true
ENABLE_FORM_TRACKING=true

# Performance monitoring
ENABLE_REAL_USER_MONITORING=true
PERFORMANCE_BUDGET_LCP=2500
PERFORMANCE_BUDGET_FID=100
PERFORMANCE_BUDGET_CLS=0.1

# SEO automation
AUTO_SITEMAP_GENERATION=true
AUTO_SCHEMA_MARKUP=true
AUTO_META_OPTIMIZATION=true

# Notification settings (för SEO alerts)
SLACK_WEBHOOK_URL=your_slack_webhook_for_seo_alerts
EMAIL_ALERTS_RECIPIENT=admin@jobbcoach.ai